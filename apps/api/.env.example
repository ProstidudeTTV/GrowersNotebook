# Copy to .env in this folder. Required for the API to read/write Postgres (Seed data, feeds, etc.).
#
# Persistence: point DATABASE_URL at your Supabase project DB, then after every pull that
# adds migrations run from repo root: pnpm db:migrate (or apply supabase/migrations in Dashboard).

# Supabase → Project Settings → Database → URI (Direct or pooler; include password).
# Direct host shape: db.<project-ref>.supabase.co — append ?sslmode=require for Node clients.
# Session pooler (use host from Dashboard → Connect, e.g. aws-1-us-west-2.pooler.supabase.com:5432).
# URL-encode special characters in the password (e.g. ! → %21, @ → %40).
DATABASE_URL=

# Supabase → Project Settings → API → JWT Secret (HS256 / legacy tokens only)
SUPABASE_JWT_SECRET=

# Same project URL as the web app (required if access tokens use asymmetric signing / JWKS)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

WEB_ORIGIN=http://localhost:3000
PORT=3001
