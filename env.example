# Copy to apps/web/.env.local and apps/api/.env (or use a shared secret manager).
# Optionally: one file at the REPO ROOT named `.env` with DATABASE_URL + SUPABASE_JWT_SECRET;
# the API loads root `.env` then merges `apps/api/.env` (see apps/api/src/app.module.ts).
# Supabase: Dashboard → Settings → API (Project URL, anon key, JWT Secret under "JWT Settings" / legacy).

# --- apps/web (.env.local) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Anon JWT is used first for Auth/Realtime (avoid 401s). Publishable is fallback if anon unset.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_jwt
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Required: base URL of the Nest API (no trailing slash). Local example in YOUR .env.local only:
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
# Matrix client URL (public HTTPS in production). Optional until messaging is configured.
# NEXT_PUBLIC_MATRIX_HOMESERVER_URL=https://matrix.yourdomain.com
# Supabase Dashboard → Authentication → URL configuration:
# Add your site origin + /auth/callback (local and production) to Redirect URLs
# so confirmation emails can exchange the code and land on /auth/complete.

# Local Next dev bind (optional; default 127.0.0.1). Set to 0.0.0.0 in YOUR env for LAN — do not hardcode in repo.
# NEXT_DEV_BIND=127.0.0.1
# NEXT_DEV_PORT=3000

# --- apps/api (.env) ---
# Direct db host is often IPv6-only; on Windows use Session pooler (Dashboard → Connect) instead, e.g.:
# postgresql://postgres.YOUR_REF:[PASSWORD]@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

SUPABASE_JWT_SECRET=your_jwt_secret
# Required for RS256/ES256 user JWTs (matches NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Public origin of the web app (CORS). Required when NODE_ENV=production (e.g. https://your-app.onrender.com).
WEB_ORIGIN=http://127.0.0.1:3000
PORT=3001
# Listen address (required in production — set in Render env, e.g. 0.0.0.0). Local default in code is 127.0.0.1 when unset.
LISTEN_HOST=127.0.0.1

# --- Matrix / Synapse (optional; see infra/synapse/README.md) ---
# SYNAPSE_BASE_URL=http://127.0.0.1:8010
# SYNAPSE_PUBLIC_BASE_URL=http://127.0.0.1:8010
# Server name in MXIDs (@user:server.name); must match Synapse server_name / certificates.
# SYNAPSE_SERVER_NAME=localhost
# Admin user access token (Synapse “User token” from an admin-capable account).
# SYNAPSE_ADMIN_ACCESS_TOKEN=
# Shared secret; same value as jwt_config.secret in homeserver.yaml.
# SYNAPSE_JWT_SECRET=

# --- Render (dashboard env after linking GitHub + blueprint) ---
# API service: DATABASE_URL, SUPABASE_*, WEB_ORIGIN (production site URL), LISTEN_HOST=0.0.0.0, PORT set by Render,
# plus SYNAPSE_* when Matrix is live.
# Web service: NEXT_PUBLIC_* (API URL = your Render API URL), optional NEXT_PUBLIC_MATRIX_HOMESERVER_URL.
# Postgres: growers-matrix-postgres from render.yaml supplies credentials; paste into Synapse homeserver database section.

# --- Schema / persistence (Supabase Postgres) ---
# Agent-oriented reference: docs/supabase-mcp-handbook.md (tables, MCP apply_migration, Realtime).
# The API uses DATABASE_URL — that must be the SAME database as your Supabase project.
# New tables (follows, etc.) only exist after migrations run on that database.
#
# Recommended: Drizzle (source of truth for Nest)
#   From repo root: pnpm db:migrate
#   (runs apps/api/drizzle/*.sql against DATABASE_URL; use Session pooler URI on Windows.)
# drizzle.config.ts pins __drizzle_migrations to schema public — see docs/supabase-mcp-handbook.md
#
# If you deploy schema via Supabase CLI or Dashboard instead, also run the SQL under
# supabase/migrations/ (kept in sync with Drizzle for convenience). Running BOTH on the
# same DB is safe when files use IF NOT EXISTS / idempotent patterns where noted.
#
# Demo content: pnpm db:seed (after migrate; needs DATABASE_URL in apps/api/.env)

# Supabase Realtime (run SQL in the Dashboard on the hosted DB if not using CLI):
# - `supabase/migrations/20260404000000_enable_realtime_comments.sql` → `public.comments`
# - `supabase/migrations/20260405180000_realtime_post_and_comment_votes.sql` → vote tables
# Requires Drizzle migration `0001_faithful_squadron_supreme` (`comment_votes.post_id`) so
# Realtime can filter `comment_votes` with `post_id=eq.<uuid>`.

# First admin: after your profile row exists, promote with:
#   UPDATE public.profiles SET role = 'admin' WHERE id = '<auth.users.id>';
