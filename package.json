{
  "name": "growers-notebook",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.cjs",
    "ports:free": "node scripts/free-dev-ports.cjs",
    "build": "node scripts/build.cjs",
    "lint": "npx turbo lint",
    "install:all": "npx pnpm@9.15.9 install",
    "db:generate": "npx pnpm@9.15.9 --filter @growers/api db:generate",
